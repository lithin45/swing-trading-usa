# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# All secrets are read by Pydantic with the prefix SWING_ (see swing_signals/config_loader.py).
# Nothing here is needed for the Stage 1 scaffold; leave blank until the relevant stage.

# --- Data providers (free tiers) ---
# FRED (macro + VIX) — free key: https://fred.stlouisfed.org/docs/api/api_key.html
SWING_FRED_API_KEY=
# Finnhub (news, earnings calendar, insider) — free 60 req/min: https://finnhub.io/register
SWING_FINNHUB_API_KEY=
# Stooq price fallback (OPTIONAL) — free key, captcha: https://stooq.com/q/d/?s=aapl.us&get_apikey
# Leave blank to disable the fallback; yfinance is the primary price source.
SWING_STOOQ_API_KEY=
# SEC EDGAR requires a descriptive User-Agent (your email), not a key.
SWING_SEC_EDGAR_USER_AGENT=your-name your-email@example.com

# --- Alerting (Stage 6) ---
# Telegram: create a bot via @BotFather, then get your chat id.
SWING_TELEGRAM_BOT_TOKEN=
SWING_TELEGRAM_CHAT_ID=
# Email backup (SMTP).
SWING_SMTP_HOST=
SWING_SMTP_PORT=587
SWING_SMTP_USER=
SWING_SMTP_PASSWORD=
SWING_SMTP_FROM=
SWING_SMTP_TO=

# --- Monitoring (Stage 7) ---
# healthchecks.io dead-man's-switch ping URL.
SWING_HEALTHCHECK_URL=
# Optional second check for the intraday manage workflow.
SWING_HEALTHCHECK_INTRADAY_URL=

# --- Stage 8: automated paper trading + AI + cloud DB (all optional) ---
# Alpaca PAPER keys — https://alpaca.markets (Paper Trading). Never live money.
# Required to place paper trades; also the preferred (reliable) price source.
SWING_ALPACA_API_KEY=
SWING_ALPACA_SECRET_KEY=
# Anthropic API key — https://console.anthropic.com — powers the news factor + daily brief.
SWING_ANTHROPIC_API_KEY=
# Alpha Vantage free key (optional news source + the earnings-date backfill that
# makes the backtest's earnings veto replayable) — https://www.alphavantage.co/support/#api-key
SWING_ALPHAVANTAGE_API_KEY=
# Tiingo free key (fallback price provider; covers many DELISTED tickers — shrinks
# the survivorship residual) — https://www.tiingo.com/account/api/token
SWING_TIINGO_API_KEY=
# Neon/Supabase Postgres URL for cross-run history + the dashboard. CI/Streamlit use a
# bare DATABASE_URL; locally set SWING_DATABASE_URL. Falls back to sqlite:///signals.db.
SWING_DATABASE_URL=
# Dashboard password (also set as `dashboard_password` in Streamlit Cloud secrets).
SWING_DASHBOARD_PASSWORD=
